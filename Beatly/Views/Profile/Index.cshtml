@model Beatly.Models.ProfileViewModel

<div class="profile-page" style="background-color: #12141c; padding: 32px; border-radius: 16px; color: #ffffff; font-family: 'Inter', sans-serif; max-width: 600px; margin: 0 auto;">
    <div style="display: flex; align-items: center; gap: 24px; margin-bottom: 32px;">
        <img src="@Model.ProfilePicturePath" alt="Avatar" style="width: 96px; height: 96px; border-radius: 50%; object-fit: cover; border: 2px solid #0071e3;" />
        <div>
            <h2 style="margin: 0 0 4px 0; font-size: 24px; font-weight: 600;">@Model.FullName</h2>
            <p style="margin: 0; color: #8e8e93; font-size: 15px;">@Model.Email</p>
            @if (Model.IsPremium)
            {
                <span style="display: inline-block; background-color: #0071e3; color: #ffffff; font-size: 12px; font-weight: 600; padding: 4px 8px; border-radius: 6px; margin-top: 8px;">Premium</span>
            }
        </div>
    </div>

    <div style="background-color: #1c1e26; border-radius: 12px; padding: 20px; margin-bottom: 24px;">
        <h3 style="margin: 0 0 16px 0; font-size: 18px; font-weight: 600; display: flex; align-items: center; gap: 8px;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
            Связанные социальные сети
        </h3>

        <div style="display: flex; flex-direction: column; gap: 12px;">
            <div>
                <span style="color: #8e8e93; font-size: 14px; display: block; margin-bottom: 4px;">Instagram</span>
                @if (!string.IsNullOrEmpty(Model.InstagramUrl))
                {
                    <a href="@Model.InstagramUrl" target="_blank" rel="noopener noreferrer" style="color: #0071e3; text-decoration: none; font-size: 16px; font-weight: 500;">@Model.InstagramUrl</a>
                }
                else
                {
                    <span style="color: #48484a; font-style: italic; font-size: 15px;">Не указан</span>
                }
            </div>

            <div style="margin-top: 8px;">
                <span style="color: #8e8e93; font-size: 14px; display: block; margin-bottom: 4px;">Telegram</span>
                @if (!string.IsNullOrEmpty(Model.TelegramUrl))
                {
                    <a href="@Model.TelegramUrl" target="_blank" rel="noopener noreferrer" style="color: #0071e3; text-decoration: none; font-size: 16px; font-weight: 500;">@Model.TelegramUrl</a>
                }
                else
                {
                    <span style="color: #48484a; font-style: italic; font-size: 15px;">Не указан</span>
                }
            </div>
        </div>

        <div style="margin-top: 20px; border-top: 1px solid #2c2e38; padding-top: 16px;">
            <a asp-action="SocialMedia" style="display: inline-block; background-color: #2c2e38; color: #ffffff; text-decoration: none; padding: 10px 16px; border-radius: 8px; font-size: 14px; font-weight: 500; transition: background-color 0.2s;">
                Редактировать ссылки
            </a>
        </div>
    </div>
</div>
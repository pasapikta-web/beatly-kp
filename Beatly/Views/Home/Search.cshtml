@model IEnumerable<Beatly.Models.Track>

@{
    ViewData["Title"] = "Поиск";
}

<div class="p-8 text-white min-h-screen">

    <div class="mb-8 relative max-w-3xl">
        <form asp-action="Search" method="get" class="relative w-full">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
            </div>
            <input type="text" id="pageSearchInput" name="query" class="w-full bg-[#1c1c24] text-white rounded-full py-3 pl-10 pr-10 focus:outline-none focus:ring-2 focus:ring-[#499BED] transition-all" placeholder="Поиск треков, артистов..." value="@Context.Request.Query["query"]" autocomplete="off" />
            <button type="button" id="pageClearSearchBtn" class="hidden absolute inset-y-0 right-0 pr-4 flex items-center text-gray-400 hover:text-white transition">
                <span class="material-symbols-outlined text-lg">close</span>
            </button>
        </form>

        <!-- Smart Search Dropdown -->
        <div id="pageSearchDropdown" class="hidden absolute left-0 right-0 top-full mt-2 bg-[#1c1c24] border border-white/10 rounded-2xl shadow-2xl overflow-hidden z-50">
            <div class="p-2 max-h-[450px] overflow-y-auto custom-scrollbar">
                <div id="pageSearchTracksSection" class="mb-3 hidden">
                    <div class="text-[11px] font-bold text-gray-500 uppercase tracking-wider px-3 py-2">Треки</div>
                    <div id="pageTracksContainer" class="space-y-0.5"></div>
                </div>

                <div id="pageSearchArtistsSection" class="hidden">
                    <div class="text-[11px] font-bold text-gray-500 uppercase tracking-wider px-3 py-2">Исполнители</div>
                    <div id="pageArtistsContainer" class="space-y-0.5"></div>
                </div>

                <div id="pageSearchEmptyState" class="hidden text-center py-8 text-sm text-gray-400">
                    Ничего не найдено
                </div>
            </div>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <h2 class="text-2xl font-bold mb-6">Результаты поиска</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-6">
            @foreach (var track in Model)
            {
                <div class="bg-[#18181d] rounded-lg p-4 hover:bg-[#28282d] transition group cursor-pointer">
                    <div class="relative mb-4">
                        <img src="@track.CoverUrl" alt="@track.Title" class="w-full aspect-square object-cover rounded-md" onerror="this.src='/images/default-cover.jpg'" />
                        <button class="absolute bottom-2 right-2 bg-blue-500 rounded-full p-3 opacity-0 group-hover:opacity-100 transition transform translate-y-2 group-hover:translate-y-0" onclick="playTrack('@track.AudioUrl', '@track.Title', '@track.Artist', '@track.CoverUrl')">
                            <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" clip-rule="evenodd"></path></svg>
                        </button>
                    </div>
                    <h3 class="font-bold truncate text-sm">@track.Title</h3>
                    <p class="text-gray-400 text-xs truncate">@track.Artist</p>
                </div>
            }
        </div>
    }
    else if (!string.IsNullOrEmpty(Context.Request.Query["query"]))
    {
        <div class="text-center text-gray-400 mt-12">
            <p class="text-xl">По вашему запросу ничего не найдено.</p>
        </div>
    }
    else
    {
        <h1 class="text-3xl font-bold mb-6">Жанры</h1>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
            <a asp-action="Category" asp-route-type="Genre" asp-route-name="Рок" class="relative rounded-xl h-40 overflow-hidden cursor-pointer group block">
                <img src="https://images.unsplash.com/photo-1498038432885-c6f3f1b912ee?auto=format&fit=crop&w=400&q=80" alt="Рок" class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition duration-500" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent group-hover:from-black/70 transition"></div>
                <span class="font-bold text-2xl absolute bottom-4 left-4 drop-shadow-md text-white">Рок</span>
            </a>

            <a asp-action="Category" asp-route-type="Genre" asp-route-name="Поп" class="relative rounded-xl h-40 overflow-hidden cursor-pointer group block">
                <img src="https://images.unsplash.com/photo-1514525253161-7a46d19cd819?auto=format&fit=crop&w=400&q=80" alt="Поп" class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition duration-500" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent group-hover:from-black/70 transition"></div>
                <span class="font-bold text-2xl absolute bottom-4 left-4 drop-shadow-md text-white">Поп</span>
            </a>

            <a asp-action="Category" asp-route-type="Genre" asp-route-name="Электроника" class="relative rounded-xl h-40 overflow-hidden cursor-pointer group block">
                <img src="https://images.unsplash.com/photo-1514525253161-7a46d19cd819?auto=format&fit=crop&w=400&q=80" alt="Электроника" class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition duration-500" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent group-hover:from-black/70 transition"></div>
                <span class="font-bold text-2xl absolute bottom-4 left-4 drop-shadow-md text-white">Электроника</span>
            </a>

            <a asp-action="Category" asp-route-type="Genre" asp-route-name="Хип-Хоп" class="relative rounded-xl h-40 overflow-hidden cursor-pointer group block">
                <img src="https://images.unsplash.com/photo-1508973379184-7517410fb0bc?auto=format&fit=crop&w=400&q=80" alt="Хип-Хоп" class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition duration-500" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent group-hover:from-black/70 transition"></div>
                <span class="font-bold text-2xl absolute bottom-4 left-4 drop-shadow-md text-white">Хип-Хоп</span>
            </a>

            <a asp-action="Category" asp-route-type="Genre" asp-route-name="Джаз" class="relative rounded-xl h-40 overflow-hidden cursor-pointer group block">
                <img src="https://images.unsplash.com/photo-1511192336575-5a79af67a629?auto=format&fit=crop&w=400&q=80" alt="Джаз" class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition duration-500" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent group-hover:from-black/70 transition"></div>
                <span class="font-bold text-2xl absolute bottom-4 left-4 drop-shadow-md text-white">Джаз</span>
            </a>

            <a asp-action="Category" asp-route-type="Genre" asp-route-name="Классика" class="relative rounded-xl h-40 overflow-hidden cursor-pointer group block">
                <img src="https://images.unsplash.com/photo-1507838153414-b4b713384a76?auto=format&fit=crop&w=400&q=80" alt="Классика" class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition duration-500" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent group-hover:from-black/70 transition"></div>
                <span class="font-bold text-2xl absolute bottom-4 left-4 drop-shadow-md text-white">Классика</span>
            </a>

            <a asp-action="Category" asp-route-type="Genre" asp-route-name="Инди" class="relative rounded-xl h-40 overflow-hidden cursor-pointer group block">
                <img src="https://images.unsplash.com/photo-1493225457124-a1a2a5f27c32?auto=format&fit=crop&w=400&q=80" alt="Инди" class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition duration-500" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent group-hover:from-black/70 transition"></div>
                <span class="font-bold text-2xl absolute bottom-4 left-4 drop-shadow-md text-white">Инди</span>
            </a>

            <a asp-action="Category" asp-route-type="Genre" asp-route-name="R&B" class="relative rounded-xl h-40 overflow-hidden cursor-pointer group block">
                <img src="https://images.unsplash.com/photo-1493225255756-d9584f8606e9?auto=format&fit=crop&w=400&q=80" alt="R&B" class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition duration-500" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent group-hover:from-black/70 transition"></div>
                <span class="font-bold text-2xl absolute bottom-4 left-4 drop-shadow-md text-white">R&B</span>
            </a>

            <a asp-action="Category" asp-route-type="Genre" asp-route-name="Метал" class="relative rounded-xl h-40 overflow-hidden cursor-pointer group block">
                <img src="https://images.unsplash.com/photo-1598387181032-a3103a2db5b3?auto=format&fit=crop&w=400&q=80" alt="Метал" class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition duration-500" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent group-hover:from-black/70 transition"></div>
                <span class="font-bold text-2xl absolute bottom-4 left-4 drop-shadow-md text-white">Метал</span>
            </a>

            <a asp-action="Category" asp-route-type="Genre" asp-route-name="Альтернатива" class="relative rounded-xl h-40 overflow-hidden cursor-pointer group block">
                <img src="https://images.unsplash.com/photo-1511671782779-c97d3d27a1d4?auto=format&fit=crop&w=400&q=80" alt="Альтернатива" class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition duration-500" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent group-hover:from-black/70 transition"></div>
                <span class="font-bold text-2xl absolute bottom-4 left-4 drop-shadow-md text-white">Альтернатива</span>
            </a>

            <a asp-action="Category" asp-route-type="Genre" asp-route-name="Шансон" class="relative rounded-xl h-40 overflow-hidden cursor-pointer group block">
                <img src="https://images.unsplash.com/photo-1525201548942-d8732f6617a0?auto=format&fit=crop&w=400&q=80" alt="Шансон" class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition duration-500" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent group-hover:from-black/70 transition"></div>
                <span class="font-bold text-2xl absolute bottom-4 left-4 drop-shadow-md text-white">Шансон</span>
            </a>

            <a asp-action="Category" asp-route-type="Genre" asp-route-name="Фолк" class="relative rounded-xl h-40 overflow-hidden cursor-pointer group block">
                <img src="https://images.unsplash.com/photo-1459749411175-04bf5292ceea?auto=format&fit=crop&w=400&q=80" alt="Фолк" class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition duration-500" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent group-hover:from-black/70 transition"></div>
                <span class="font-bold text-2xl absolute bottom-4 left-4 drop-shadow-md text-white">Фолк</span>
            </a>
        </div>
    }
</div>

@section Scripts {
    <script>
        document.addEventListener('turbo:load', () => {
            const searchInput = document.getElementById('pageSearchInput');
            const searchDropdown = document.getElementById('pageSearchDropdown');
            const clearBtn = document.getElementById('pageClearSearchBtn');

            const tracksSection = document.getElementById('pageSearchTracksSection');
            const tracksContainer = document.getElementById('pageTracksContainer');
            const artistsSection = document.getElementById('pageSearchArtistsSection');
            const artistsContainer = document.getElementById('pageArtistsContainer');
            const emptyState = document.getElementById('pageSearchEmptyState');

            let debounceTimeout;

            if (!searchInput) return;

            searchInput.addEventListener('input', () => {
                const query = searchInput.value.trim();

                if (query.length > 0) {
                    clearBtn.classList.remove('hidden');
                } else {
                    clearBtn.classList.add('hidden');
                    hideDropdown();
                    return;
                }

                clearTimeout(debounceTimeout);
                debounceTimeout = setTimeout(() => {
                    fetchSuggestions(query);
                }, 300);
            });

            clearBtn.addEventListener('click', () => {
                searchInput.value = '';
                clearBtn.classList.add('hidden');
                hideDropdown();
                searchInput.focus();
            });

            document.addEventListener('click', (e) => {
                if (!searchInput.contains(e.target) && !searchDropdown.contains(e.target)) {
                    hideDropdown();
                }
            });

            searchInput.addEventListener('focus', () => {
                if (searchInput.value.trim().length > 0) {
                    searchDropdown.classList.remove('hidden');
                }
            });

            function hideDropdown() {
                if (searchDropdown) searchDropdown.classList.add('hidden');
            }

            function fetchSuggestions(query) {
                fetch(`/api/searchapi/suggest?query=${encodeURIComponent(query)}`)
                    .then(res => {
                        if (!res.ok) throw new Error();
                        return res.json();
                    })
                    .then(data => {
                        renderSuggestions(data);
                    })
                    .catch(() => {
                        hideDropdown();
                    });
            }

            function renderSuggestions(data) {
                tracksContainer.innerHTML = '';
                artistsContainer.innerHTML = '';

                const hasTracks = data.tracks && data.tracks.length > 0;
                const hasArtists = data.artists && data.artists.length > 0;

                if (!hasTracks && !hasArtists) {
                    tracksSection.classList.add('hidden');
                    artistsSection.classList.add('hidden');
                    emptyState.classList.remove('hidden');
                    searchDropdown.classList.remove('hidden');
                    return;
                }

                emptyState.classList.add('hidden');

                if (hasTracks) {
                    data.tracks.forEach(track => {
                        const trackRow = document.createElement('div');
                        trackRow.className = "flex items-center gap-3 p-2 hover:bg-white/5 rounded-xl cursor-pointer transition group";
                        trackRow.onclick = () => {
                            if (typeof window.playTrack === 'function') {
                                window.playTrack(track.url || `/audio/${track.id}.mp3`, track.title, track.artist, track.coverPath);
                            } else {
                                location.href = `/Tracks/Details/${track.id}`;
                            }
                        };
                        trackRow.innerHTML = `
                        <div class="w-10 h-10 rounded-lg overflow-hidden bg-gray-800 flex-shrink-0 relative">
                            <img src="${track.coverPath || '/images/default-cover.png'}" class="w-full h-full object-cover">
                            <div class="absolute inset-0 bg-black/40 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                                <span class="material-symbols-outlined text-white text-xl">play_arrow</span>
                            </div>
                        </div>
                        <div class="flex-1 min-w-0">
                            <div class="text-sm font-semibold text-white truncate">${track.title}</div>
                            <div class="text-xs text-gray-400 truncate mt-0.5">${track.artist}</div>
                        </div>
                        `;
                        tracksContainer.appendChild(trackRow);
                    });
                    tracksSection.classList.remove('hidden');
                } else {
                    tracksSection.classList.add('hidden');
                }

                if (hasArtists) {
                    data.artists.forEach(artist => {
                        const artistRow = document.createElement('div');
                        artistRow.className = "flex items-center gap-3 p-2.5 hover:bg-white/5 rounded-xl cursor-pointer transition text-sm font-medium text-gray-200 hover:text-white";
                        artistRow.onclick = () => {
                            location.href = `/Home/Search?query=${encodeURIComponent(artist)}`;
                        };
                        artistRow.innerHTML = `
                        <span class="material-symbols-outlined text-gray-400 text-lg">music_note</span>
                        <span class="truncate">${artist}</span>
                        `;
                        artistsContainer.appendChild(artistRow);
                    });
                    artistsSection.classList.remove('hidden');
                } else {
                    artistsSection.classList.add('hidden');
                }

                searchDropdown.classList.remove('hidden');
            }
        });
    </script>
}
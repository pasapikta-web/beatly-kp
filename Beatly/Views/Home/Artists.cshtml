@model IEnumerable<IGrouping<string, Beatly.Models.Track>>

@{
    ViewData["Title"] = "Исполнители";
}

<div class="space-y-8">
    <h2 class="text-3xl font-black text-white">Исполнители</h2>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-6">
        @foreach (var artist in Model)
        {
            <div class="bg-[#181a20] p-6 rounded-[2rem] border border-white/5 hover:bg-white/10 transition text-center group cursor-pointer">
                <div class="w-24 h-24 mx-auto mb-4 rounded-full bg-gradient-to-tr from-[#499BED] to-cyan-500 flex items-center justify-center shadow-lg shadow-[#499BED]/20">
                    <span class="text-2xl font-black text-white">@artist.Key[0]</span>
                </div>
                <h3 class="font-bold text-white truncate">@artist.Key</h3>
                <p class="text-[#499BED] text-[10px] font-bold uppercase mt-1">Артист</p>
            </div>
        }
    </div>
</div>
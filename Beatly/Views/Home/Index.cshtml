@model IEnumerable<Beatly.Models.Track>
@{
    ViewData["Title"] = "Главная";
}

<style>
    @@keyframes gradient-x {
        0%, 100% {
            background-position: 0% 50%;
        }

        50% {
            background-position: 100% 50%;
        }
    }

    .animate-gradient-x {
        background-size: 200% 200%;
        animation: gradient-x 10s ease infinite;
    }

    .hide-scrollbar::-webkit-scrollbar {
        display: none;
    }

    .hide-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }

    .glass-panel {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

        .glass-panel:hover {
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(73, 155, 237, 0.3);
        }

    .text-glow {
        text-shadow: 0 0 20px rgba(73, 155, 237, 0.5);
    }
</style>

<section class="relative h-[450px] rounded-[2rem] overflow-hidden mb-14 shadow-[0_0_50px_rgba(73,155,237,0.15)] group">
    <img src="https://images.unsplash.com/photo-1470225620780-dba8ba36b745?w=1600" class="absolute inset-0 w-full h-full object-cover scale-105 group-hover:scale-100 transition-transform duration-1000 ease-out" />
    <div class="absolute inset-0 bg-gradient-to-r from-[#0a0a0a] via-[#0a0a0a]/80 to-transparent"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-[#0a0a0a] via-transparent to-transparent"></div>

    <div class="absolute inset-0 p-12 flex flex-col justify-center w-full md:w-2/3">
        <div class="flex items-center gap-3 mb-6">
            <span class="bg-gradient-to-r from-[#499BED] to-purple-500 text-white text-xs font-black px-4 py-1.5 rounded-full uppercase tracking-wider shadow-[0_0_15px_rgba(73,155,237,0.4)]">Новый релиз</span>
            <span class="text-gray-400 text-sm font-medium">Эксклюзивно</span>
        </div>

        <h1 class="text-6xl md:text-7xl font-black text-white mb-4 leading-tight text-glow">Midnight<br /><span class="text-transparent bg-clip-text bg-gradient-to-r from-[#499BED] to-purple-400">Synth</span></h1>
        <p class="text-gray-300 text-lg mb-8 max-w-md leading-relaxed">Погрузитесь в атмосферу ночного города с новым альбомом. Неоновые огни, пульсирующий бит и бесконечная свобода.</p>

        <div class="flex flex-wrap items-center gap-4">
            <a asp-action="Category" asp-route-type="Mood" asp-route-name="Вечеринка" class="bg-[#499BED] hover:bg-[#3a82c9] text-white font-bold py-4 px-8 rounded-full flex items-center gap-2 transition-all duration-300 hover:scale-105 hover:shadow-[0_0_25px_rgba(73,155,237,0.5)]">
                <span class="material-symbols-outlined text-2xl">play_circle</span>
                Слушать сейчас
            </a>
            <a asp-action="Favorites" class="glass-panel text-white font-bold py-4 px-8 rounded-full flex items-center gap-2 transition-all duration-300 hover:scale-105">
                <span class="material-symbols-outlined text-xl">favorite</span>
                К любимым
            </a>
        </div>
    </div>
</section>

<div class="flex items-center justify-between mb-8">
    <h3 class="text-3xl font-black text-white tracking-tight">Настроения и Жанры</h3>
    <div class="flex gap-2">
        <button onclick="scrollGenres(-400)" class="w-10 h-10 rounded-full glass-panel flex items-center justify-center hover:bg-[#499BED] transition-colors">
            <span class="material-symbols-outlined">chevron_left</span>
        </button>
        <button onclick="scrollGenres(400)" class="w-10 h-10 rounded-full glass-panel flex items-center justify-center hover:bg-[#499BED] transition-colors">
            <span class="material-symbols-outlined">chevron_right</span>
        </button>
    </div>
</div>

<div id="genresSlider" class="flex overflow-x-auto hide-scrollbar gap-6 pb-8 snap-x scroll-smooth mb-8">
    <a asp-action="Category" asp-route-type="Mood" asp-route-name="Релакс" class="min-w-[240px] h-32 rounded-2xl p-6 bg-gradient-to-br from-teal-500 to-emerald-600 flex items-end snap-start transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_10px_30px_rgba(20,184,166,0.3)] relative overflow-hidden group">
        <span class="material-symbols-outlined absolute top-4 right-4 text-white/30 text-5xl group-hover:scale-125 transition-transform duration-500">spa</span>
        <span class="text-xl font-bold text-white relative z-10">Релакс</span>
    </a>
    <a asp-action="Category" asp-route-type="Mood" asp-route-name="Энергия" class="min-w-[240px] h-32 rounded-2xl p-6 bg-gradient-to-br from-purple-600 to-blue-600 flex items-end snap-start transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_10px_30px_rgba(147,51,234,0.3)] relative overflow-hidden group">
        <span class="material-symbols-outlined absolute top-4 right-4 text-white/30 text-5xl group-hover:scale-125 transition-transform duration-500">bolt</span>
        <span class="text-xl font-bold text-white relative z-10">Энергия</span>
    </a>
    <a asp-action="Category" asp-route-type="Mood" asp-route-name="Фокус" class="min-w-[240px] h-32 rounded-2xl p-6 bg-gradient-to-br from-indigo-600 to-cyan-600 flex items-end snap-start transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_10px_30px_rgba(79,70,229,0.3)] relative overflow-hidden group">
        <span class="material-symbols-outlined absolute top-4 right-4 text-white/30 text-5xl group-hover:scale-125 transition-transform duration-500">menu_book</span>
        <span class="text-xl font-bold text-white relative z-10">Фокус</span>
    </a>
    <a asp-action="Category" asp-route-type="Mood" asp-route-name="Вечеринка" class="min-w-[240px] h-32 rounded-2xl p-6 bg-gradient-to-br from-pink-500 to-rose-600 flex items-end snap-start transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_10px_30px_rgba(236,72,153,0.3)] relative overflow-hidden group">
        <span class="material-symbols-outlined absolute top-4 right-4 text-white/30 text-5xl group-hover:scale-125 transition-transform duration-500">celebration</span>
        <span class="text-xl font-bold text-white relative z-10">Вечеринка</span>
    </a>
    <a asp-action="Category" asp-route-type="Mood" asp-route-name="Сон" class="min-w-[240px] h-32 rounded-2xl p-6 bg-gradient-to-br from-blue-800 to-slate-900 flex items-end snap-start transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_10px_30px_rgba(30,41,59,0.5)] relative overflow-hidden group border border-gray-800">
        <span class="material-symbols-outlined absolute top-4 right-4 text-white/30 text-5xl group-hover:scale-125 transition-transform duration-500">bedtime</span>
        <span class="text-xl font-bold text-white relative z-10">Сон</span>
    </a>
    <a asp-action="Category" asp-route-type="Mood" asp-route-name="Спорт" class="min-w-[240px] h-32 rounded-2xl p-6 bg-gradient-to-br from-orange-500 to-red-600 flex items-end snap-start transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_10px_30px_rgba(234,88,12,0.3)] relative overflow-hidden group">
        <span class="material-symbols-outlined absolute top-4 right-4 text-white/30 text-5xl group-hover:scale-125 transition-transform duration-500">fitness_center</span>
        <span class="text-xl font-bold text-white relative z-10">Спорт</span>
    </a>
    <a asp-action="Category" asp-route-type="Mood" asp-route-name="Романтика" class="min-w-[240px] h-32 rounded-2xl p-6 bg-gradient-to-br from-red-500 to-pink-600 flex items-end snap-start transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_10px_30px_rgba(220,38,38,0.3)] relative overflow-hidden group">
        <span class="material-symbols-outlined absolute top-4 right-4 text-white/30 text-5xl group-hover:scale-125 transition-transform duration-500">favorite</span>
        <span class="text-xl font-bold text-white relative z-10">Романтика</span>
    </a>
    <a asp-action="Category" asp-route-type="Mood" asp-route-name="Дорога" class="min-w-[240px] h-32 rounded-2xl p-6 bg-gradient-to-br from-amber-500 to-orange-600 flex items-end snap-start transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_10px_30px_rgba(245,158,11,0.3)] relative overflow-hidden group">
        <span class="material-symbols-outlined absolute top-4 right-4 text-white/30 text-5xl group-hover:scale-125 transition-transform duration-500">directions_car</span>
        <span class="text-xl font-bold text-white relative z-10">Дорога</span>
    </a>
    <a asp-action="Category" asp-route-type="Mood" asp-route-name="Гейминг" class="min-w-[240px] h-32 rounded-2xl p-6 bg-gradient-to-br from-violet-600 to-fuchsia-700 flex items-end snap-start transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_10px_30px_rgba(124,58,237,0.3)] relative overflow-hidden group">
        <span class="material-symbols-outlined absolute top-4 right-4 text-white/30 text-5xl group-hover:scale-125 transition-transform duration-500">sports_esports</span>
        <span class="text-xl font-bold text-white relative z-10">Гейминг</span>
    </a>
    <a asp-action="Category" asp-route-type="Mood" asp-route-name="Меланхолия" class="min-w-[240px] h-32 rounded-2xl p-6 bg-gradient-to-br from-cyan-700 to-blue-800 flex items-end snap-start transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_10px_30px_rgba(6,182,212,0.3)] relative overflow-hidden group">
        <span class="material-symbols-outlined absolute top-4 right-4 text-white/30 text-5xl group-hover:scale-125 transition-transform duration-500">cloud</span>
        <span class="text-xl font-bold text-white relative z-10">Меланхолия</span>
    </a>
    <a asp-action="Category" asp-route-type="Mood" asp-route-name="Утро" class="min-w-[240px] h-32 rounded-2xl p-6 bg-gradient-to-br from-yellow-500 to-amber-500 flex items-end snap-start transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_10px_30px_rgba(234,179,8,0.3)] relative overflow-hidden group">
        <span class="material-symbols-outlined absolute top-4 right-4 text-white/30 text-5xl group-hover:scale-125 transition-transform duration-500">light_mode</span>
        <span class="text-xl font-bold text-white relative z-10">Утро</span>
    </a>
    <a asp-action="Category" asp-route-type="Mood" asp-route-name="Чилл" class="min-w-[240px] h-32 rounded-2xl p-6 bg-gradient-to-br from-emerald-400 to-teal-500 flex items-end snap-start transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_10px_30px_rgba(16,185,129,0.3)] relative overflow-hidden group">
        <span class="material-symbols-outlined absolute top-4 right-4 text-white/30 text-5xl group-hover:scale-125 transition-transform duration-500">self_improvement</span>
        <span class="text-xl font-bold text-white relative z-10">Чилл</span>
    </a>
    <a asp-action="Category" asp-route-type="Mood" asp-route-name="Медитация" class="min-w-[240px] h-32 rounded-2xl p-6 bg-gradient-to-br from-sky-500 to-indigo-500 flex items-end snap-start transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_10px_30px_rgba(14,165,233,0.3)] relative overflow-hidden group">
        <span class="material-symbols-outlined absolute top-4 right-4 text-white/30 text-5xl group-hover:scale-125 transition-transform duration-500">brightness_7</span>
        <span class="text-xl font-bold text-white relative z-10">Медитация</span>
    </a>
    <a asp-action="Category" asp-route-type="Mood" asp-route-name="Вдохновение" class="min-w-[240px] h-32 rounded-2xl p-6 bg-gradient-to-br from-fuchsia-500 to-purple-700 flex items-end snap-start transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_10px_30px_rgba(217,70,239,0.3)] relative overflow-hidden group">
        <span class="material-symbols-outlined absolute top-4 right-4 text-white/30 text-5xl group-hover:scale-125 transition-transform duration-500">psychology</span>
        <span class="text-xl font-bold text-white relative z-10">Вдохновение</span>
    </a>
    <a asp-action="Category" asp-route-type="Mood" asp-route-name="Ностальгия" class="min-w-[240px] h-32 rounded-2xl p-6 bg-gradient-to-br from-stone-600 to-neutral-800 flex items-end snap-start transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_10px_30px_rgba(87,83,78,0.4)] relative overflow-hidden group border border-stone-700">
        <span class="material-symbols-outlined absolute top-4 right-4 text-white/30 text-5xl group-hover:scale-125 transition-transform duration-500">history</span>
        <span class="text-xl font-bold text-white relative z-10">Ностальгия</span>
    </a>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-10 mb-16">
    <div class="lg:col-span-2">
        <div class="flex items-center justify-between mb-6">
            <h3 class="text-3xl font-black text-white tracking-tight">Популярные треки</h3>
            <a href="/Tracks" class="text-sm font-semibold text-[#499BED] hover:text-white transition-colors uppercase tracking-wider">Смотреть все</a>
        </div>

        <div class="space-y-3">
            @foreach (var track in Model)
            {
                <div class="glass-panel grid grid-cols-[auto_1fr_auto] items-center gap-4 p-3 pr-6 rounded-2xl transition-all duration-300 group cursor-pointer"
                     onclick="playTrack('@track.AudioUrl', '@track.Title', '@track.Artist', '@track.CoverUrl')">

                    <div class="relative w-14 h-14 flex items-center justify-center">
                        <span class="text-gray-400 font-bold group-hover:opacity-0 transition-opacity absolute">@track.Id</span>
                        <div class="absolute inset-0 bg-[#499BED] rounded-full opacity-0 group-hover:opacity-100 transition-all duration-300 scale-50 group-hover:scale-100 flex items-center justify-center shadow-[0_0_15px_rgba(73,155,237,0.6)]">
                            <span class="material-symbols-outlined text-white text-2xl ml-0.5">play_arrow</span>
                        </div>
                    </div>

                    <div class="flex items-center gap-5">
                        <div class="relative overflow-hidden rounded-xl">
                            <img src="@track.CoverUrl" class="w-14 h-14 object-cover group-hover:scale-110 transition-transform duration-500" />
                            <div class="absolute inset-0 bg-black/20 group-hover:bg-transparent transition-colors"></div>
                        </div>
                        <div class="flex flex-col justify-center">
                            <div class="font-bold text-white text-base group-hover:text-[#499BED] transition-colors line-clamp-1">@track.Title</div>
                            <div class="text-sm text-gray-400 font-medium hover:text-gray-200 transition-colors inline-block w-max">@track.Artist</div>
                        </div>
                    </div>

                    <div class="flex items-center gap-6">
                        <span class="text-sm text-gray-400 hidden md:block w-32 truncate font-medium hover:text-white transition-colors">@track.Album</span>

                        <div class="flex items-center gap-5">
                            <button type="button" onclick="event.stopPropagation(); toggleLike(@track.Id, this)" class="flex items-center justify-center transition-transform hover:scale-125 focus:outline-none">
                                <span class="material-symbols-outlined transition-colors duration-300 @(track.IsLiked ? "text-red-500 fill-1" : "text-gray-500 hover:text-white")">
                                    favorite
                                </span>
                            </button>
                            <span class="text-sm font-medium text-gray-400 w-12 text-right">@track.Duration</span>
                            <button type="button" onclick="event.stopPropagation()" class="text-gray-500 hover:text-white transition-colors">
                                <span class="material-symbols-outlined">more_horiz</span>
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="lg:col-span-1">
        <h3 class="text-3xl font-black text-white tracking-tight mb-6">Топ Артисты</h3>
        <div class="glass-panel rounded-3xl p-6">
            <div class="flex flex-col gap-6">
                <a href="/Artists/1" class="flex items-center gap-4 group">
                    <img src="https://images.unsplash.com/photo-1516280440502-a2f02bbf61b5?w=150" class="w-16 h-16 rounded-full object-cover border-2 border-transparent group-hover:border-[#499BED] transition-all" />
                    <div>
                        <h4 class="text-white font-bold group-hover:text-[#499BED] transition-colors">The Weeknd</h4>
                        <p class="text-xs text-gray-400 mt-1">12M слушателей</p>
                    </div>
                </a>
                <a href="/Artists/2" class="flex items-center gap-4 group">
                    <img src="https://images.unsplash.com/photo-1520813792240-56fc4a3765a7?w=150" class="w-16 h-16 rounded-full object-cover border-2 border-transparent group-hover:border-[#499BED] transition-all" />
                    <div>
                        <h4 class="text-white font-bold group-hover:text-[#499BED] transition-colors">Dua Lipa</h4>
                        <p class="text-xs text-gray-400 mt-1">10.5M слушателей</p>
                    </div>
                </a>
                <a href="/Artists/3" class="flex items-center gap-4 group">
                    <img src="https://images.unsplash.com/photo-1493225457124-a1a2a5f5f4f8?w=150" class="w-16 h-16 rounded-full object-cover border-2 border-transparent group-hover:border-[#499BED] transition-all" />
                    <div>
                        <h4 class="text-white font-bold group-hover:text-[#499BED] transition-colors">Daft Punk</h4>
                        <p class="text-xs text-gray-400 mt-1">8.2M слушателей</p>
                    </div>
                </a>
                <a href="/Artists/4" class="flex items-center gap-4 group">
                    <img src="https://images.unsplash.com/photo-1570295999919-56ceb5ecca61?w=150" class="w-16 h-16 rounded-full object-cover border-2 border-transparent group-hover:border-[#499BED] transition-all" />
                    <div>
                        <h4 class="text-white font-bold group-hover:text-[#499BED] transition-colors">Kavinsky</h4>
                        <p class="text-xs text-gray-400 mt-1">5M слушателей</p>
                    </div>
                </a>
            </div>
            <button class="w-full mt-6 py-3 rounded-xl border border-gray-600 text-gray-300 hover:bg-white hover:text-black font-bold transition-all">Все артисты</button>
        </div>
    </div>
</div>

<section class="rounded-[2rem] p-10 animate-gradient-x bg-gradient-to-r from-indigo-900 via-purple-900 to-[#499BED] flex flex-col md:flex-row items-center justify-between shadow-[0_0_40px_rgba(73,155,237,0.2)]">
    <div class="mb-6 md:mb-0 max-w-xl">
        <h2 class="text-4xl font-black text-white mb-3">Открой Beatly Premium</h2>
        <p class="text-blue-100 text-lg">Слушай музыку без рекламы, скачивай треки и наслаждайся высочайшим качеством звука.</p>
    </div>
    <div class="flex gap-4">
        <a asp-controller="Home" asp-action="Premium" class="bg-white text-black font-bold py-4 px-8 rounded-full hover:scale-105 transition-transform shadow-xl">Попробовать бесплатно</a>
    </div>
</section>

<script>
    function scrollGenres(distance) {
        const slider = document.getElementById('genresSlider');
        if (slider) {
            slider.scrollBy({ left: distance, behavior: 'smooth' });
        }
    }
</script>
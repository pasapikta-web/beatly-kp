@model IEnumerable<Beatly.Models.Track>

@{
    ViewData["Title"] = "Любимые треки";
    bool isPremium = User.Identity.IsAuthenticated && (User.HasClaim(c => c.Type == "Premium" && c.Value == "True") || User.IsInRole("Premium"));
}

<div class="p-6 font-sans">
    <div class="flex items-end gap-6 mb-8 w-full">
        <div class="w-48 h-48 rounded-2xl bg-gradient-to-br from-red-500 to-red-600 flex items-center justify-center shadow-2xl shadow-black/40">
            <span class="material-symbols-outlined text-white text-7xl fill-1">favorite</span>
        </div>
        <div class="flex flex-col gap-1 w-full flex-1">
            <span class="text-xs font-bold text-[#0071e3] tracking-wider uppercase">Плейлист</span>
            <h1 class="text-5xl font-black text-white tracking-tight">Любимые треки</h1>
            <div class="flex justify-between items-end w-full">
                <p class="text-sm text-gray-400 mt-1">
                    Все, что вам понравилось • <span class="text-white font-medium">@Model?.Count() треков</span>
                </p>
                @if(isPremium && Model != null && Model.Any())
                {
                    <button id="downloadBtn" onclick="downloadSelectedTracks()" class="bg-[#0071e3] text-white px-5 py-2.5 rounded-xl font-bold flex items-center gap-2 hover:bg-[#005bb5] transition hover:scale-105 active:scale-95 shadow-lg shadow-[#0071e3]/30">
                        <span class="material-symbols-outlined text-xl">download</span>
                        <span id="downloadBtnText">Скачать все</span>
                    </button>
                }
            </div>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="bg-[#121214]/40 border border-white/5 rounded-2xl p-4 backdrop-blur-md">
            <div class="grid @(isPremium ? "grid-cols-[48px_32px_4fr_3fr_120px]" : "grid-cols-[48px_4fr_3fr_120px]") gap-4 px-4 py-3 text-xs font-bold text-gray-500 uppercase tracking-wider border-b border-white/5 mb-2">
                <span class="text-center">#</span>
                @if(isPremium)
                {
                    <span class="flex items-center justify-center">
                        <input type="checkbox" id="selectAllCheckbox" class="w-4 h-4 rounded border-gray-600 bg-gray-700 text-[#0071e3] focus:ring-[#0071e3]" onchange="toggleAllCheckboxes(this)">
                    </span>
                }
                <span>Название</span>
                <span>Альбом</span>
                <span class="flex justify-end items-center pr-2">
                    <span class="material-symbols-outlined text-base">schedule</span>
                </span>
            </div>

            <div class="space-y-1">
                @{
                    int index = 1;
                }
                @foreach (var track in Model)
                {
                    <div class="grid @(isPremium ? "grid-cols-[48px_32px_4fr_3fr_120px]" : "grid-cols-[48px_4fr_3fr_120px]") items-center gap-4 p-3 rounded-xl hover:bg-white/5 transition group cursor-pointer"
                         onclick="playTrack('@track.AudioUrl', '@track.Title', '@track.Artist', '@track.CoverUrl')">

                        <div class="relative flex items-center justify-center w-full text-sm font-semibold text-gray-400">
                            <span class="group-hover:opacity-0 transition-opacity">@index</span>
                            <span class="material-symbols-outlined text-[#0071e3] absolute opacity-0 group-hover:opacity-100 transition-opacity text-xl">play_arrow</span>
                        </div>

                        @if(isPremium)
                        {
                            <div class="flex items-center justify-center" onclick="event.stopPropagation()">
                                <input type="checkbox" value="@track.Id" class="track-checkbox w-4 h-4 rounded border-gray-600 bg-gray-700 text-[#0071e3] focus:ring-[#0071e3]" onchange="updateDownloadButton()">
                            </div>
                        }

                        <div class="flex items-center gap-3 min-w-0">
                            <img src="@track.CoverUrl" class="w-10 h-10 rounded-lg shadow-md object-cover flex-shrink-0" />
                            <div class="truncate">
                                <div class="font-bold text-sm text-white truncate">@track.Title</div>
                                <div class="text-xs text-gray-400 group-hover:text-white transition-colors truncate">@track.Artist</div>
                            </div>
                        </div>

                        <div class="text-sm text-gray-400 truncate pr-4">@track.Album</div>

                        <div class="flex items-center justify-end gap-6 pr-2">
                            <button type="button" onclick="event.stopPropagation(); toggleLike(@track.Id, this)" class="like-btn flex items-center justify-center transition hover:scale-110 text-red-500">
                                <span class="material-symbols-outlined fill-1 text-xl">
                                    favorite
                                </span>
                            </button>
                            <span class="text-sm text-gray-400 font-mono w-10 text-right">@track.Duration</span>
                        </div>
                    </div>
                    index++;
                }
            </div>
        </div>
    }
    else
    {
        <div class="flex flex-col items-center justify-center py-24 text-center bg-[#121214]/20 border border-white/5 rounded-2xl">
            <span class="material-symbols-outlined text-8xl text-gray-700 mb-4">favorite</span>
            <h2 class="text-2xl font-bold text-white">Список пуст</h2>
            <p class="text-gray-400 mt-2">Отмечайте треки сердечком, чтобы они появились здесь.</p>
        </div>
    }
</div>

@if (isPremium)
{
<script>
    function toggleAllCheckboxes(source) {
        const checkboxes = document.querySelectorAll('.track-checkbox');
        checkboxes.forEach(cb => cb.checked = source.checked);
        updateDownloadButton();
    }

    function updateDownloadButton() {
        const checkedCount = document.querySelectorAll('.track-checkbox:checked').length;
        const btnText = document.getElementById('downloadBtnText');
        if (checkedCount > 0) {
            btnText.innerText = `Скачать выбранные (${checkedCount})`;
        } else {
            btnText.innerText = 'Скачать все';
        }
    }

    function downloadSelectedTracks() {
        const checkboxes = document.querySelectorAll('.track-checkbox:checked');
        let selectedIds = [];
        
        if (checkboxes.length > 0) {
            checkboxes.forEach(cb => selectedIds.push(parseInt(cb.value)));
        }
        
        const btnText = document.getElementById('downloadBtnText');
        const originalText = btnText.innerText;
        btnText.innerText = 'Скачивание...';

        fetch('/Track/DownloadMultiple', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(selectedIds.length > 0 ? selectedIds : [])
        })
        .then(response => {
            if (!response.ok) throw new Error('Download failed');
            return response.blob();
        })
        .then(blob => {
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.style.display = 'none';
            a.href = url;
            a.download = 'Beatly_Tracks.zip';
            document.body.appendChild(a);
            a.click();
            window.URL.revokeObjectURL(url);
            btnText.innerText = originalText;
        })
        .catch(err => {
            console.error(err);
            alert('Произошла ошибка при скачивании.');
            btnText.innerText = originalText;
        });
    }
</script>
}